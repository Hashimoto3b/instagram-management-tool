# ========================================
# 1. データベース（変更不要）
# ========================================
DATABASE_URL="file:./dev.db"

# ========================================
# 2. Gemini API Key（AIによる分析・コンテンツ生成に使用）
#    取得先: https://aistudio.google.com/apikey
#    ※無料で利用可能
# ========================================
GEMINI_API_KEY="ここにGemini APIキーを貼り付け"

# ========================================
# 3. Instagram Graph API（Instagramデータ取得に使用）
#    取得先: https://developers.facebook.com/
#    ※Metaビジネスアカウントが必要
# ========================================
INSTAGRAM_APP_ID="ここにApp IDを貼り付け"
INSTAGRAM_APP_SECRET="ここにApp Secretを貼り付け"
INSTAGRAM_ACCESS_TOKEN="ここにアクセストークンを貼り付け"
